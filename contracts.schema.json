{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/accolver/spec-to-ship/schemas/contracts.schema.json",
  "type": "object",
  "required": [
    "name",
    "version",
    "category",
    "triggers",
    "antiTriggers",
    "inputs",
    "outputs",
    "approvalPolicy",
    "verification",
    "stopRules"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "antiTriggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "approvalPolicy": {
      "type": "string"
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "stopRules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "toolPolicy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
